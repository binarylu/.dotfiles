[filter "lfs"]
    required = true
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
[core]
    # git >= 1.7.12 auto-reads ~/.config/git/ignore via XDG — no excludesfile needed.
    editor = vim

    # autocrlf is set per-platform in git/platform.{mac,linux,win}
[alias]
    st = status
    ci = commit
    co = checkout
    sw = switch
    br = branch
    lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>(%ae)[%G?]%Creset' --abbrev-commit
    d = difftool
    d2 = difftool --tool=bc --dir-diff
    m = mergetool
    m2 = mergetool --tool=bc
[pager]
    diff = false
    branch = false
[diff]
    tool = vimdiff
    algorithm = histogram
[difftool]
    prompt = false
[difftool "bc"]
    trustExitCode = true
[merge]
    tool = vimdiff
    conflictstyle = diff3
[mergetool]
    prompt = false
[mergetool "bc"]
    trustExitCode = true
[fetch]
    prune = true
[pull]
    ff = only
[include]
    path = ~/.config/git/platform
    path = ~/.config/git/local
