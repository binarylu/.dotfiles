"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
" XDG Base Directory {{{
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
if !has('nvim') && has('patch-9.1.0327')
    let $XDG_CONFIG_HOME = !empty($XDG_CONFIG_HOME) ? $XDG_CONFIG_HOME : $HOME . '/.config'
    let $XDG_DATA_HOME   = !empty($XDG_DATA_HOME)   ? $XDG_DATA_HOME   : $HOME . '/.local/share'
    let $XDG_STATE_HOME  = !empty($XDG_STATE_HOME)  ? $XDG_STATE_HOME  : $HOME . '/.local/state'
    let $XDG_CACHE_HOME  = !empty($XDG_CACHE_HOME)  ? $XDG_CACHE_HOME  : $HOME . '/.cache'
    set runtimepath^=$XDG_DATA_HOME/vim
    set runtimepath+=$XDG_DATA_HOME/vim/after
    set packpath^=$XDG_DATA_HOME/vim,$XDG_CONFIG_HOME/vim
    set packpath+=$XDG_DATA_HOME/vim/after,$XDG_CONFIG_HOME/vim/after
    set viminfofile=$XDG_STATE_HOME/vim/viminfo
    set undodir=$XDG_STATE_HOME/vim/undo
    " Trailing // tells vim to use the full file path in swap/backup filenames,
    " preventing collisions when editing files with the same name in different dirs.
    set directory=$XDG_CACHE_HOME/vim/swap//
    set backupdir=$XDG_CACHE_HOME/vim/backup//
    set viewdir=$XDG_CACHE_HOME/vim/view
    silent! call mkdir(&undodir,   'p', 0700)
    silent! call mkdir(&directory, 'p', 0700)
    silent! call mkdir(&backupdir, 'p', 0700)
    silent! call mkdir(&viewdir,   'p', 0700)
endif
" }}}

"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
" Plugins {{{
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
" Automatic installation of vim-plug
let data_dir = has('nvim') ? stdpath('data') . '/site' : (has('patch-9.1.0327') ? $XDG_DATA_HOME . '/vim' : $HOME . '/.vim')
if empty(glob(data_dir . '/autoload/plug.vim'))
  silent execute '!curl -sS -fLo '.data_dir.'/autoload/plug.vim --create-dirs https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim'
  autocmd VimEnter * PlugInstall --sync | source $MYVIMRC
endif

if empty(glob(data_dir . '/after/syntax/sh/slurm.vim'))
  silent execute '!curl -sS -fLo '.data_dir.'/after/syntax/sh/slurm.vim --create-dirs https://raw.githubusercontent.com/SchedMD/slurm/refs/heads/master/contribs/slurm_completion_help/slurm.vim'
endif

call plug#begin()
Plug 'tpope/vim-sensible'
Plug 'vim-scripts/restore_view.vim'     " automatically save and restore view

Plug 'preservim/tagbar'
Plug 'preservim/nerdcommenter'
Plug 'dense-analysis/ale'                   " async lint / fix; LSP client (:help ale)
Plug 'jiangmiao/auto-pairs'
Plug 'Valloric/ListToggle'                  " A simple vim plugin for toggling the display of the quickfix list and the location-list
Plug 'tkhoa2711/vim-togglenumber'
Plug 'tmhedberg/SimpylFold'                 " Fold python code more precise
Plug 'airblade/vim-gitgutter'               " shows a git diff in the 'gutter' (sign column).
Plug 'tpope/vim-fugitive'                   " git integration, used for branch name in statusline
Plug 'ntpeters/vim-better-whitespace'       " highlight and strip trailing whitespace
Plug 'noahfrederick/vim-skeleton'           " populate new files from skeleton templates

Plug 'catppuccin/vim', { 'as': 'catppuccin' }
Plug 'vim-airline/vim-airline'

" plug#end() automatically executes filetype plugin indent on and syntax enable
call plug#end()
" }}}

