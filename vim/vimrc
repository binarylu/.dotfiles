"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
" General Settings {{{
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
" allow switching buffers without saving
set hidden
" Use the OS clipboard by default (on versions compiled with `+clipboard`)
set clipboard=unnamed
set visualbell
" Enable per-directory .vimrc files and disable unsafe commands in them
set exrc
set secure
" Allow specified keys that move the cursor left/right to move to the previous/next line when the cursor is on the first/last character in the line.
set whichwrap=b,s,<,>,[,]
" Don't create backups when editing files in certain directories
set backupskip=/tmp/*,/private/tmp/*
set undofile

" Don't reset cursor to start of line when moving around.
set nostartofline
set title
" Save and restore terminal title around vim
let &t_ti .= "\e[22;0t"
let &t_te .= "\e[23;0t"

set encoding=utf-8 nobomb
set fencs=utf-8,ucs-bom,cp936,gb18030,big5,euc-jp,euc-kr,latin1
" When open binary files, display the values by hex
set display+=uhex

let mapleader=","
" Use F9 to toggle paste mode
set pastetoggle=<F9>

set ignorecase
" case-sensitive when pattern contains uppercase
set smartcase
set hlsearch
set showmatch
set termguicolors
set cursorline

set tabstop=4
set shiftwidth=4
set softtabstop=4
set expandtab
set autoindent
set number
set relativenumber
" Show invisible characters
set listchars=tab:▸\ ,trail:·,eol:¬,nbsp:_
set foldmethod=indent
" }}}

"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
" Theme {{{
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
augroup CustomHighlights
    autocmd!
    autocmd ColorScheme * hi Comment gui=italic cterm=italic
    autocmd ColorScheme * hi Keyword gui=italic cterm=italic
    autocmd ColorScheme * hi Conditional gui=italic cterm=italic
    autocmd ColorScheme * hi Repeat gui=italic cterm=italic
    autocmd ColorScheme * hi Constant gui=italic cterm=italic
    autocmd ColorScheme * hi Boolean gui=italic cterm=italic
    autocmd ColorScheme * hi Type gui=italic cterm=italic
    autocmd ColorScheme * hi StorageClass gui=italic cterm=italic
augroup END

if has('gui_running')
    set guifont=Maple\ Mono\ NF\ CN:h14

    function! s:SyncTheme()
        if v:os_appearance
            let g:airline_theme = 'catppuccin_mocha'
            colorscheme catppuccin_mocha
        else
            let g:airline_theme = 'catppuccin_latte'
            colorscheme catppuccin_latte
        endif
        if exists(':AirlineRefresh')
            AirlineRefresh
        endif
        redraw!
    endfunction

    augroup AutoDarkMode
        autocmd!
        autocmd OSAppearanceChanged * call s:SyncTheme()
    augroup END
    call s:SyncTheme()
else
    colorscheme catppuccin_mocha
endif

" }}}

"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
" Functions {{{
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
" Remove CR from buffer (ff=unix but lines still have CRLF / stray ^M).
" Each CRLF becomes LF; save to persist. Not for pure dos files where Vim
" omitted CR — then :set ff=unix | w is enough.
function! RemoveCR()
    let save_cursor = getpos(".")
    keeppatterns %s/\%x0d//ge
    call setpos('.', save_cursor)
endfunction

function! ToggleTextwidth()
    if &textwidth == 76
        set textwidth=0
        echo 'textwidth=0'
    else
        set textwidth=76
        echo 'textwidth=76'
    endif
endfunction

" }}}

"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
" autocmd {{{
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
augroup VimrcAutocmds
    autocmd!
    autocmd FileType ruby,eruby,html setlocal tabstop=2 shiftwidth=2 softtabstop=2
    " Remove comment leader when joining lines (run after filetype plugins)
    autocmd FileType * setlocal formatoptions+=j
    " Do not highlight the current line when entering insert mode
    autocmd InsertEnter * setlocal nocursorline
    " Do not highlight the current line when leaving the current window
    autocmd WinLeave * setlocal nocursorline
    " Highlight the current line after leaving insert mode
    autocmd InsertLeave * setlocal cursorline
    " Highlight the current line after entering a new window
    autocmd WinEnter * setlocal cursorline
augroup END
" }}}

"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
" Map {{{
" Check the key description: :h key-notation
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
" Normal + Visual
noremap <leader>ss :StripWhitespace<CR>

" Normal
nnoremap <space>       za
nnoremap <leader><CR>  :nohlsearch<CR>
nnoremap <leader>W     :w !sudo tee % > /dev/null<CR>
nnoremap <leader>cr    :call RemoveCR()<CR>
nnoremap <leader>ls    :set invlist<CR>
nnoremap <leader>m     :let &mouse = (&mouse ==# 'a' ? '' : 'a')<CR>
nnoremap <leader>n     :ToggleNumber<CR>
nnoremap <leader>tb    :TagbarToggle<CR>
nnoremap <leader>tw    :call ToggleTextwidth()<CR>
nnoremap <C-h>         <C-w>h
nnoremap <C-j>         <C-w>j
nnoremap <C-k>         <C-w>k
nnoremap <C-l>         <C-w>l

" }}}

